{
  "enabledPlugins": {
    "autofix-bot@claude-plugins-official": true
  },
  "autoMemoryEnabled": false,
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "mcp__memory-global__read_graph",
      "mcp__memory-global__search_nodes",
      "mcp__memory-global__open_nodes",
      "mcp__memory-global__add_observations",
      "mcp__memory-global__create_entities",
      "mcp__memory-global__create_relations",
      "mcp__memory-project__read_graph",
      "mcp__memory-project__search_nodes",
      "mcp__memory-project__open_nodes",
      "mcp__memory-project__add_observations",
      "mcp__memory-project__create_entities",
      "mcp__memory-project__create_relations",
      "mcp__azure-devops__wit_get_work_item",
      "mcp__azure-devops__wit_update_work_item",
      "mcp__azure-devops__wit_create_work_item",
      "mcp__azure-devops__wit_add_work_item_comment",
      "mcp__azure-devops__wit_add_child_work_items",
      "mcp__azure-devops__wit_my_work_items",
      "mcp__azure-devops__wit_query_by_wiql",
      "mcp__azure-devops__search_workitem",
      "mcp__azure-devops__search_code",
      "mcp__azure-devops__repo_list_pull_requests_by_repo_or_project",
      "mcp__azure-devops__repo_create_pull_request",
      "mcp__azure-devops__repo_get_pull_request_by_id",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__directory_tree",
      "mcp__filesystem__read_file",
      "mcp__filesystem__read_text_file",
      "mcp__filesystem__read_multiple_files",
      "mcp__filesystem__write_file",
      "mcp__filesystem__edit_file",
      "mcp__filesystem__create_directory",
      "mcp__filesystem__get_file_info",
      "mcp__filesystem__search_files",
      "mcp__filesystem__list_allowed_directories",
      "mcp__filesystem__list_directory_with_sizes",
      "mcp__filesystem__move_file",
      "mcp__supabase-test__postgrestRequest",
      "mcp__supabase-test__sqlToRest",
      "mcp__supabase-prod__list_tables",
      "mcp__supabase-prod__execute_sql",
      "mcp__supabase-prod__get_logs",
      "mcp__supabase-prod__get_advisors",
      "mcp__supabase-prod__list_migrations",
      "mcp__supabase-prod__list_edge_functions",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'MEMORY REMINDER: A commit was just made. Per docs/memory-policy.md, /end-work should APPEND + CURATE memory-project (HOT): update active-work, prune stale obs, demote closed work to memory-deep. Back up first (files are gitignored).'",
            "if": "Bash(git commit*)",
            "statusMessage": "Checking post-commit memory save..."
          }
        ]
      }
    ]
  }
}
